  "description": "Monorepo for pinequest-s3-e2-team-9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @pinequest/web",
    "dev:web": "npm run dev --workspace @pinequest/web",
    "dev:api": "npm run dev --workspace @pinequest/api",
    "build": "npm run build --workspace @pinequest/web",
