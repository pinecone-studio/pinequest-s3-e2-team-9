{
  "name": "pinequest-s3-e2-team-9",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for pinequest-s3-e2-team-9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/web && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "dev:api": "cd apps/api && bun run dev",
    "build": "cd apps/web && bun run build",
    "build:web": "cd apps/web && bun run build",
    "build:api": "cd apps/api && bun run build",
    "build:pages": "cd apps/web && bun run build:pages",
    "start": "cd apps/web && bun run start",
    "start:api": "cd apps/api && bun run start",
    "lint": "cd apps/web && bun run lint",
    "type-check": "cd apps/web && bun run type-check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pinecone-studio/pinequest-s3-e2-team-9.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/pinecone-studio/pinequest-s3-e2-team-9/issues"
  },
  "homepage": "https://github.com/pinecone-studio/pinequest-s3-e2-team-9#readme",
  "dependencies": {}
}
