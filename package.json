{
  "name": "pinequest-s3-e2-team-9",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for pinequest-s3-e2-team-9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @pinequest/web",
    "dev:web": "npm run dev --workspace @pinequest/web",
    "dev:api": "npm run dev --workspace @pinequest/api",
    "dev:pdf-service": "node --env-file=apps/pdf-extraction-service/.env apps/pdf-extraction-service/server.mjs",
    "dev:pdf-service:python": "python3 apps/pdf-extraction-python-service/server.py",
    "stress:test": "sh scripts/stress-test.sh",
    "stress:test:k6": "k6 run scripts/stress-test.k6.js",
    "stress:test:teacher-dashboard": "sh scripts/stress-test-teacher-dashboard.sh",
    "stress:test:teacher-dashboard:soak": "sh scripts/stress-test-teacher-dashboard-soak.sh",
    "stress:test:class-detail": "sh scripts/stress-test-class-detail.sh",
    "stress:test:write-save-answer": "sh scripts/stress-test-save-answer.sh",
    "stress:test:realtime-smoke": "sh scripts/realtime-sse-smoke.sh",
    "build": "npm run build --workspace @pinequest/web",
    "build:web": "npm run build --workspace @pinequest/web",
    "build:worker": "npm run build:worker --workspace @pinequest/web",
    "build:api": "npm run build --workspace @pinequest/api",
    "start": "npm run start --workspace @pinequest/web",
    "start:api": "npm run start --workspace @pinequest/api",
    "lint": "npm run lint --workspace @pinequest/web",
    "type-check": "npm run type-check --workspace @pinequest/web",
    "preview:web": "npm run preview --workspace @pinequest/web",
    "deploy:web": "npm run deploy --workspace @pinequest/web"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pinecone-studio/pinequest-s3-e2-team-9.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/pinecone-studio/pinequest-s3-e2-team-9/issues"
  },
  "homepage": "https://github.com/pinecone-studio/pinequest-s3-e2-team-9#readme",
  "dependencies": {}
}
