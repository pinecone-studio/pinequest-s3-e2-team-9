    "build:worker": "npm run build:worker --workspace @pinequest/web",
    "build:api": "npm run build --workspace @pinequest/api",
    "start": "npm run start --workspace @pinequest/web",
    "start:api": "npm run start --workspace @pinequest/api",
    "lint": "npm run lint --workspace @pinequest/web",
    "type-check": "npm run type-check --workspace @pinequest/web",
    "preview:web": "npm run preview --workspace @pinequest/web",
    "deploy:web": "npm run deploy --workspace @pinequest/web"
  },
  "repository": {
    "type": "git",
